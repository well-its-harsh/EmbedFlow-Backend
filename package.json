    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register server.ts",
    "worker-dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/services/file-processing.worker.service.ts",
    "worker-pipeline": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/services/minio-bullmq-pipeline.service.ts",
    "lint": "eslint '{src,server.ts}/**/*.{ts,js}' --fix",
    "format": "prettier --write '{src,server.ts}/**/*.{ts,js,json,md}'"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
